{
  "name": "connect-platform",
  "version": "1.0.0",
  "description": "Connect Platform - Document Management and Service Guidance",
  "private": true,
  "scripts": {
    "frontend:dev": "cd frontend && pnpm dev",
    "frontend:build": "cd frontend && pnpm build",
    "backend:dev": "cd backend && pnpm dev",
    "backend:build": "cd backend && pnpm build",
    "dev": "npm-run-all --parallel frontend:dev backend:dev",
    "build": "npm-run-all frontend:build backend:build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.19",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "mongoose": "^9.6.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "tw-animate-css": "^1.4.0"
  }
}
